# Dark Nova ][ LLM proxy — environment configuration.
# Copy to .env (or a systemd EnvironmentFile) and fill in the key.

# Server-side Anthropic API key. Optional if every client brings its own key
# via the X-Api-Key header (BYOK), but normally you want this set.
ANTHROPIC_API_KEY=sk-ant-...

# Port to listen on.
PORT=8095

# Comma-separated list of allowed CORS origins for Flutter web builds,
# or * for any. Native (iOS/Android/desktop) clients don't need CORS.
ALLOWED_ORIGINS=*

# --- Optional tuning (defaults shown) ---------------------------------------

# Claude model used for all prose generation.
#ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Hard deadline per Claude call, in ms. On expiry the proxy answers 503 and
# the game's engine-side canned prose takes over.
#LLM_TIMEOUT_MS=3000

# Max output tokens per Claude call.
#LLM_MAX_TOKENS=400

# Per-IP token bucket: instant burst size and sustained requests/minute.
#RATE_LIMIT_BURST=10
#RATE_LIMIT_PER_MINUTE=30

# In-memory response cache.
#CACHE_MAX_ENTRIES=500
#DIALOGUE_CACHE_TTL_MS=900000     # 15 minutes
#NEWS_CACHE_TTL_MS=86400000       # 24 hours (news is deterministic per seed+day)

# Set to 1 when running behind a reverse proxy (nginx/caddy) so the rate
# limiter sees real client IPs from X-Forwarded-For.
#TRUST_PROXY=0
